<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>INIntentsSupported</key>
	<array>
		<string>INPlayMediaIntent</string>
		<string>INSearchForMediaIntent</string>
	</array>
	<key>INSupportedMediaCategories</key>
	<array>
		<string>INMediaCategoryVideo</string>
		<string>INMediaCategoryMusic</string>
	</array>
	<key>NSAppleMusicUsageDescription</key>
	<string>MediaManager plays music from your library through Siri voice commands.</string>
	<key>NSSiriUsageDescription</key>
	<string>MediaManager uses Siri to play media from your library by voice.</string>
	<key>NSUserActivityTypes</key>
	<array>
		<string>INPlayMediaIntent</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<!--
		  Per-role scene configuration. The default phone scene
		  (UIWindowSceneSessionRoleApplication) is intentionally
		  not declared here — SwiftUI's App protocol handles it
		  automatically and adding an explicit entry would either
		  override our SwiftUI scene or require a custom UIKit
		  scene delegate. The CarPlay role MUST be declared so
		  iOS knows to wire CarPlaySceneDelegate when a head
		  unit (or the Xcode CarPlay simulator) connects.
		-->
		<key>UISceneConfigurations</key>
		<dict>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>CarPlay Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
<key>CFBundleDisplayName</key>
	<string>$(APP_DISPLAY_NAME)</string>
<key>NSCameraUsageDescription</key>
	<string>Camera access is needed to scan barcodes on disc packaging.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Face ID is used to sign in to your Household Disc Keeper account.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Local network access is used to discover your Household Disc Keeper server automatically.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!--
	  Background audio entitlement. Lets AVPlayer keep going when the
	  screen locks or the app moves to the background — without this
	  the music stops the moment the lock-screen comes on, which makes
	  the app useless for headphone listening.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!--
	  Pre-answers the App Store Connect "does your app use encryption?"
	  question every TestFlight upload. We use only HTTPS / TLS via the
	  system networking stack and Apple's Keychain — both exempt under
	  US BIS rules — so we declare "no non-exempt encryption" and
	  uploads flow straight to "Ready to Test" without a manual click.
	  Flip to <true/> only if we ever ship custom crypto.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
