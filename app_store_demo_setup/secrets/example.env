# Demo-server secrets template. Copy to secrets/.env (gitignored)
# and fill in real values before running scripts that need
# authenticated admin API calls.
#
# The first admin still has to come from the /setup wizard — those
# values are what you typed into the wizard, not credentials the
# scripts create.

# Admin account created by the /setup wizard.
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASSWORD=change-me-after-setup

# Passwords for the additional accounts seed-users.sh creates.
# Picked something memorable enough for App Review reviewers to
# type but not so weak it shows up in credential dumps.
DEMO_VIEWER_PASSWORD=change-me
DEMO_KID_PASSWORD=change-me
DEMO_EMPTY_PASSWORD=change-me

# URL of the running demo server. seed-users.sh and link-fixtures.sh
# log in here. Default is the docker-compose default.
DEMO_BASE_URL=http://localhost:8080
