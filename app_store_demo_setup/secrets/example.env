# Demo-server secrets template. Copy to secrets/.env (gitignored)
# and fill in real values before running scripts that need
# authenticated admin API calls.
#
# Format: KEY=VALUE per line, shell-sourceable. Generate passwords
# with a password manager — don't pick them by hand. Avoid shell
# metacharacters ($ ` " \) so the file can be sourced without
# quoting.
#
# Account roster (full table in app_store_demo_setup/README.md):
#
#   admin           — Demo-server admin. Bootstrapped via /setup
#                     wizard (NOT by seed-users). Used by our scripts
#                     and screenshot capture. Never given to Apple.
#   reviewer-admin  — Admin credential pasted into App Store Connect
#                     for App Review. Never used by us.
#   reviewer        — Unrestricted non-admin given to App Review.
#                     Never used by us.
#   reviewer-kid    — Max-restricted (TV-Y) given to App Review.
#                     Never used by us.
#   viewer          — Our screenshot-capture viewer.
#   kid             — PG-13 ceiling. Rating-gate screenshots.
#   empty           — No history / no wishes. Empty-state screenshots.
#
# The first admin still has to come from the /setup wizard — admin-
# create requires an existing admin to authenticate, so the very
# first one bootstraps from the wizard. seed-users logs in as
# DEMO_ADMIN_USER / DEMO_ADMIN_PASSWORD and creates the other six.
#
# Apple-shared accounts (reviewer-admin, reviewer, reviewer-kid) are
# created by seed-users with terms_of_use_accepted_at left NULL, so
# the App Review reviewer is forced through the ToS acceptance flow
# on first login.

# --- Bootstrapped via /setup wizard ---
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASSWORD=change-me

# --- Created by seed-users — given to Apple App Review ---
# username: reviewer-admin
DEMO_REVIEWER_ADMIN_PASSWORD=change-me
# username: reviewer
DEMO_REVIEWER_PASSWORD=change-me
# username: reviewer-kid
DEMO_REVIEWER_KID_PASSWORD=change-me

# --- Created by seed-users — used for screenshot capture ---
DEMO_VIEWER_PASSWORD=change-me
DEMO_KID_PASSWORD=change-me
DEMO_EMPTY_PASSWORD=change-me

# --- Legal document URLs entered into the /setup wizard ---
# The setup form accepts HTTPS URLs or the literal "about:blank"
# (placeholder, configurable later via Settings). Apple App Review
# will require real, reachable URLs before approval.
DEMO_PRIVACY_POLICY_URL=about:blank
DEMO_TERMS_OF_USE_URL=about:blank

# URL of the running demo server. seed-users and link-fixtures log
# in here.
DEMO_BASE_URL=https://appstoredemo.15mcmahon.net:8443
