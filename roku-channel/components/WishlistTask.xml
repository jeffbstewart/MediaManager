        <!-- Inputs -->
        <field id="wishUrl" type="string" />
        <field id="wishBody" type="string" />

        <!-- Outputs -->
        <field id="wishResult" type="assocarray" alwaysNotify="true" />
        <field id="wishError" type="string" alwaysNotify="true" />
