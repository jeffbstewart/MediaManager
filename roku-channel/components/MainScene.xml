<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
    <interface>
        <field id="voiceSearchQuery" type="string" alwaysNotify="true" onChange="onVoiceSearchQuery" />
    </interface>

    <script type="text/brightscript" uri="MainScene.brs" />

    <children>
        <!-- Dark background -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="#1a1a2e" />

        <!-- Screens (toggled via visibility) -->
        <ProfilePickerScreen
            id="profilePickerScreen"
            visible="false"
            translation="[0, 0]" />

        <PairScreen
            id="pairScreen"
            visible="false"
            translation="[0, 0]" />

        <HomeScreen
            id="homeScreen"
            visible="false"
            translation="[0, 0]" />

        <EpisodePickerScreen
            id="episodePickerScreen"
            visible="false"
            translation="[0, 0]" />

        <VideoPlayerScreen
            id="videoPlayerScreen"
            visible="false"
            translation="[0, 0]" />

        <!-- Pair task (shared background worker) -->
        <PairTask id="pairTask" />
    </children>
</component>
