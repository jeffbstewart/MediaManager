<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
    <interface>
        <field id="voiceSearchQuery" type="string" alwaysNotify="true" onChange="onVoiceSearchQuery" />
    </interface>

    <script type="text/brightscript" uri="MainScene.brs" />

    <children>
        <!-- Dark background -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="#1a1a2e" />

        <!-- Screens (toggled via visibility) -->
        <ProfilePickerScreen
            id="profilePickerScreen"
            visible="false"
            translation="[0, 0]" />

        <PairScreen
            id="pairScreen"
            visible="false"
            translation="[0, 0]" />

        <HomeScreen
            id="homeScreen"
            visible="false"
            translation="[0, 0]" />

        <MovieDetailScreen
            id="movieDetailScreen"
            visible="false"
            translation="[0, 0]" />

        <EpisodePickerScreen
            id="episodePickerScreen"
            visible="false"
            translation="[0, 0]" />

        <VideoPlayerScreen
            id="videoPlayerScreen"
            visible="false"
            translation="[0, 0]" />

        <SearchResultsScreen
            id="searchResultsScreen"
            visible="false"
            translation="[0, 0]" />

        <CollectionScreen
            id="collectionScreen"
            visible="false"
            translation="[0, 0]" />

        <TagScreen
            id="tagScreen"
            visible="false"
            translation="[0, 0]" />

        <ActorScreen
            id="actorScreen"
            visible="false"
            translation="[0, 0]" />

        <CameraListScreen
            id="cameraListScreen"
            visible="false"
            translation="[0, 0]" />

        <CameraPlayerScreen
            id="cameraPlayerScreen"
            visible="false"
            translation="[0, 0]" />

        <LiveTvListScreen
            id="liveTvListScreen"
            visible="false"
            translation="[0, 0]" />

        <LiveTvPlayerScreen
            id="liveTvPlayerScreen"
            visible="false"
            translation="[0, 0]" />

        <!-- Shared background tasks -->
        <PairTask id="pairTask" />
        <WishlistTask id="wishlistTask" />
    </children>
</component>
