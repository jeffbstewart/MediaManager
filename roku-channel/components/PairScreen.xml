<?xml version="1.0" encoding="utf-8" ?>
<component name="PairScreen" extends="Group">
    <interface>
        <field id="pairComplete" type="assocarray" alwaysNotify="true" />
        <field id="cancelRequested" type="boolean" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="PairScreen.brs" />

    <children>
        <!-- Background -->
        <Rectangle
            width="1920"
            height="1080"
            color="#1a1a2e" />

        <!-- Title -->
        <Label
            id="titleLabel"
            translation="[660, 100]"
            text="Add Profile"
            font="font:LargeBoldSystemFont"
            color="#e0e0e0" />

        <!-- Instructions -->
        <Label
            id="instructionLabel"
            translation="[660, 170]"
            text="Searching for server..."
            font="font:SmallSystemFont"
            color="#a0a0a0"
            width="700"
            wrap="true"
            maxLines="4" />

        <!-- QR code image (shown during pairing) -->
        <Poster
            id="qrCode"
            translation="[160, 200]"
            width="400"
            height="400"
            visible="false"
            loadDisplayMode="scaleToFit" />

        <!-- Pair code text (shown alongside QR code) -->
        <Label
            id="pairCodeLabel"
            translation="[160, 620]"
            text=""
            font="font:LargeBoldSystemFont"
            color="#ffffff"
            horizAlign="center"
            width="400"
            visible="false" />

        <!-- Pair code instruction -->
        <Label
            id="pairInstructionLabel"
            translation="[110, 680]"
            text="Or enter this code at your server"
            font="font:SmallSystemFont"
            color="#a0a0a0"
            horizAlign="center"
            width="500"
            visible="false" />

        <!-- Button group (context-sensitive) -->
        <ButtonGroup
            id="buttonGroup"
            translation="[660, 340]"
            textColor="#e0e0e0"
            focusedTextColor="#ffffff" />

        <!-- Status label -->
        <Label
            id="statusLabel"
            translation="[660, 700]"
            font="font:SmallSystemFont"
            color="#ff6b6b"
            visible="false"
            width="600"
            wrap="true" />

        <!-- Pair task (background worker) -->
        <PairTask id="pairTask" />
    </children>
</component>
