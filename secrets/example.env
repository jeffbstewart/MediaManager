# TMDB API — get free API key and access token at https://www.themoviedb.org/settings/api
TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# H2 database password (REQUIRED) — the app will not start without this.
# Use a strong random value for production.
H2_PASSWORD=
# To change the password: move current H2_PASSWORD to H2_PRIOR_PASSWORD,
# set the new password in H2_PASSWORD. Remove H2_PRIOR_PASSWORD after one startup.
# H2_PRIOR_PASSWORD=

# H2 file encryption password — enables AES encryption at rest.
# On first set, the database is automatically migrated (export/reimport).
# Once encrypted, this variable is REQUIRED on every startup.
# H2_FILE_PASSWORD=
