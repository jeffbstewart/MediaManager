# iOS app configuration — copy to ios.agent_visible_env and fill in values.
#
# Apple Developer Team ID (REQUIRED) — find in Apple Developer portal under Membership.
# Also must match DEVELOPMENT_TEAM in ios/MediaManager/Developer.xcconfig
DEVELOPMENT_TEAM=YOUR_TEAM_ID_HERE
#
# Privacy policy URL (REQUIRED) — the iOS app will not build without this.
# Generate one for free at https://www.termsfeed.com/privacy-policy-generator/
# Host it anywhere publicly accessible (GitHub Pages, your own site, etc.)
PRIVACY_POLICY_URL=https://YOUR_PRIVACY_POLICY_URL_HERE
