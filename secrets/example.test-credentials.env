# Test credentials for automated testing by AI coding agents
# Copy to secrets/test-credentials.agent_visible_env and fill in values.
#
# WHY THIS FILE EXISTS
# --------------------
# AI coding agents (Claude Code, etc.) need to log into the running app
# to verify changes: clicking through the UI with Playwright, hitting
# API endpoints, confirming access control works. Without real credentials,
# the agent can't test anything behind the login wall.
#
# The .agent_visible_env extension signals that the agent is ALLOWED to
# read this file (unlike .env files, which contain production secrets and
# are off-limits). The file is svn:ignore'd / .gitignore'd so credentials
# never enter version control.
#
# SETUP
# -----
# 1. Start the app and create your admin account via /setup
# 2. Create the test accounts below via the Users admin page
# 3. Copy this file to test-credentials.agent_visible_env
# 4. Fill in the usernames and passwords you chose
#
# Keep passwords unique to this app — these accounts exist only for
# automated testing and can be deleted or recreated at any time.

# Invalid credentials (should always be rejected — used to test login failure)
INVALID_USERNAME=baduser
INVALID_PASSWORD=wrongpassword

# Level 1 (viewer) test account
VIEWER_USERNAME=
VIEWER_PASSWORD=

# Level 2 (admin) test account
ADMIN_USERNAME=
ADMIN_PASSWORD=
